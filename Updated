# ============================================================
# APP CONFIG
# ============================================================

APP_TITLE = "Enterprise Time Tracker V5"
BASE_DIR = os.path.abspath(os.path.dirname(__file__))
SETTINGS_FILE = os.path.join(BASE_DIR, "time_tracker_settings.json")
DEFAULT_EXCEL_PATH = os.path.join(BASE_DIR, "master_time_log.xlsx")

DEFAULT_SETTINGS = {
    "excel_path": DEFAULT_EXCEL_PATH,
    "activities": [
        "Change Request",
        "Incident",
        "Meeting",
        "Development",
        "Environment Support",
        "Admin",
        "Break"
    ],
    "theme": "flatly"
}


# ============================================================
# HELPERS
# ============================================================

def seconds_to_hms(total_seconds: int) -> str:
    hours = total_seconds // 3600
    minutes = (total_seconds % 3600) // 60
    seconds = total_seconds % 60
    return f"{hours:02}:{minutes:02}:{seconds:02}"


def hms_to_seconds(hms: str) -> int:
    try:
        h, m, s = [int(x) for x in str(hms).split(":")]
        return h * 3600 + m * 60 + s
    except Exception:
        return 0


def safe_float(value, default=0.0):
    try:
        return float(value)
    except Exception:
        return default


# ============================================================
# SETTINGS
# ============================================================

def load_settings():
    if not os.path.exists(SETTINGS_FILE):
        save_settings(DEFAULT_SETTINGS)
        return DEFAULT_SETTINGS.copy()

    try:
        with open(SETTINGS_FILE, "r", encoding="utf-8") as f:
            settings = json.load(f)
    except Exception:
        save_settings(DEFAULT_SETTINGS)
        return DEFAULT_SETTINGS.copy()

    if "excel_path" not in settings:
        settings["excel_path"] = DEFAULT_EXCEL_PATH
    if "activities" not in settings or not isinstance(settings["activities"], list):
        settings["activities"] = DEFAULT_SETTINGS["activities"][:]
    if "theme" not in settings:
        settings["theme"] = "flatly"

    return settings


def save_settings(settings):
    with open(SETTINGS_FILE, "w", encoding="utf-8") as f:
        json.dump(settings, f, indent=4)


# ============================================================
# EXCEL
# ============================================================

def ensure_workbook(excel_path: str):
    if not os.path.exists(excel_path):
        wb = Workbook()
        ws = wb.active
        ws.title = "Time Log"
        ws.append([
            "Date",
            "Start Time",
            "End Time",
            "Duration Minutes",
            "Duration HH:MM:SS",
            "Activity"
        ])
        wb.save(excel_path)


def append_log_to_excel(excel_path: str, start_dt: datetime, end_dt: datetime, activity: str):
    ensure_workbook(excel_path)

    duration_seconds = max(0, int((end_dt - start_dt).total_seconds()))
    duration_minutes = round(duration_seconds / 60, 2)
    duration_hms = seconds_to_hms(duration_seconds)

    wb = load_workbook(excel_path)
    ws = wb["Time Log"] if "Time Log" in wb.sheetnames else wb.active

    ws.append([
        start_dt.strftime("%d/%m/%Y"),
        start_dt.strftime("%H:%M:%S"),
        end_dt.strftime("%H:%M:%S"),
        duration_minutes,
        duration_hms,
        activity
    ])

    wb.save(excel_path)


def read_today_logs(excel_path: str):
    ensure_workbook(excel_path)

    wb = load_workbook(excel_path, data_only=True)
    ws = wb["Time Log"] if "Time Log" in wb.sheetnames else wb.active

    today_str = datetime.now().strftime("%d/%m/%Y")
    logs = []

    for row in ws.iter_rows(min_row=2, values_only=True):
        if not row or len(row) < 6:
            continue

        row_date, start_time, end_time, duration_minutes, duration_hms, activity = row

        if str(row_date).strip() != today_str:
            continue

        logs.append({
            "date": str(row_date),
            "start": str(start_time),
            "end": str(end_time),
            "duration_minutes": safe_float(duration_minutes),
            "duration_hms": str(duration_hms),
            "activity": str(activity)
        })

    return logs


