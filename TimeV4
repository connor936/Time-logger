    def show_page(self, page_name: str):
        page = self.pages[page_name]
        page.tkraise()

        self.nav_dashboard.configure(bootstyle="outline-light")
        self.nav_logs.configure(bootstyle="outline-light")
        self.nav_settings.configure(bootstyle="outline-light")

        if page_name == "dashboard":
            self.nav_dashboard.configure(bootstyle="light")
        elif page_name == "logs":
            self.nav_logs.configure(bootstyle="light")
        elif page_name == "settings":
            self.nav_settings.configure(bootstyle="light")

    def _refresh_activity_sources(self):
        activities = self.settings["activities"]
        self.activity_combo["values"] = activities

        if activities:
            if self.activity_var.get() not in activities:
                self.activity_var.set(activities[0])

        self.activity_listbox.delete(0, tk.END)
        for activity in activities:
            self.activity_listbox.insert(tk.END, activity)

    def browse_excel(self):
        path = filedialog.asksaveasfilename(
            title="Choose master Excel workbook",
            defaultextension=".xlsx",
            filetypes=[("Excel Workbook", "*.xlsx")]
        )
        if path:
            self.excel_path_var.set(path)

    def apply_theme(self):
        new_theme = self.theme_var.get().strip()
        if not new_theme:
            return
        try:
            self.style.theme_use(new_theme)
            self.settings["theme"] = new_theme
            save_settings(self.settings)
        except Exception as e:
            messagebox.showerror("Theme Error", str(e))

    def add_activity(self):
        activity = self.new_activity_var.get().strip()
        if not activity:
            return
        if activity in self.settings["activities"]:
            messagebox.showwarning("Duplicate", "That activity already exists.")
            return

        self.settings["activities"].append(activity)
        self.new_activity_var.set("")
        self._refresh_activity_sources()

    def remove_selected_activity(self):
        selected = self.activity_listbox.curselection()
        if not selected:
            return

        idx = selected[0]
        activity = self.settings["activities"][idx]

        if self.current_activity == activity:
            messagebox.showwarning("In Use", "You cannot remove the activity that is currently running.")
            return

        del self.settings["activities"][idx]
        self._refresh_activity_sources()

    def move_activity_up(self):
        selected = self.activity_listbox.curselection()
        if not selected:
            return
        idx = selected[0]
        if idx == 0:
            return

        items = self.settings["activities"]
        items[idx - 1], items[idx] = items[idx], items[idx - 1]
        self._refresh_activity_sources()
        self.activity_listbox.selection_set(idx - 1)

    def move_activity_down(self):
        selected = self.activity_listbox.curselection()
        if not selected:
            return
        idx = selected[0]
        items = self.settings["activities"]
        if idx >= len(items) - 1:
            return

        items[idx + 1], items[idx] = items[idx], items[idx + 1]
        self._refresh_activity_sources()
        self.activity_listbox.selection_set(idx + 1)

    def save_all_settings(self):
        excel_path = self.excel_path_var.get().strip()
        if not excel_path:
            messagebox.showwarning("Missing Path", "Please choose a master Excel workbook path.")
            return

        if not self.settings["activities"]:
            messagebox.showwarning("No Activities", "Please keep at least one activity.")
            return

        self.settings["excel_path"] = excel_path
        self.settings["theme"] = self.theme_var.get().strip() or self.settings.get("theme", "flatly")

        try:
            ensure_workbook(excel_path)
            save_settings(self.settings)
            messagebox.showinfo("Saved", "Settings saved successfully.")
            self.refresh_today_views()
        except Exception as e:
            messagebox.showerror("Save Error", str(e))

    def quick_start(self, activity_name: str):
        if activity_name not in self.settings["activities"]:
            self.settings["activities"].append(activity_name)
            self._refresh_activity_sources()

        self.activity_var.set(activity_name)
        self.start_selected_activity()

    def start_selected_activity(self):
        activity = self.activity_var.get().strip()
        if not activity:
            messagebox.showwarning("No Activity", "Please choose an activity first.")
            return

        now = datetime.now()

        if self.current_activity and self.current_start_dt:
            if activity == self.current_activity:
                messagebox.showinfo(
                    "Already Running",
                    f"'{activity}' is already running."
                )
                return
            self._log_entry(self.current_start_dt, now, self.current_activity)

        self.current_activity = activity
        self.current_start_dt = now
        self._refresh_current_session_ui()
        self.refresh_today_views()

    def stop_activity(self):
        if not self.current_activity or not self.current_start_dt:
            messagebox.showinfo("No Active Task", "There is no running activity to stop.")
            return

        end_dt = datetime.now()
        self._log_entry(self.current_start_dt, end_dt, self.current_activity)

        self.current_activity = None
        self.current_start_dt = None
        self._refresh_current_session_ui()
        self.refresh_today_views()

    def _log_entry(self, start_dt: datetime, end_dt: datetime, activity: str):
        if end_dt <= start_dt:
            return

        try:
            append_log_to_excel(self.settings["excel_path"], start_dt, end_dt, activity)
        except PermissionError:
            messagebox.showerror(
                "Workbook Locked",
                "The Excel file appears to be open or locked. Please close it and try again."
            )
        except Exception as e:
            messagebox.showerror("Logging Error", f"Could not write to Excel.\n\n{e}")

    def _refresh_current_session_ui(self):
        if self.current_activity and self.current_start_dt:
            self.current_status_var.set(self.current_activity)
            self.current_start_var.set(f"Start: {self.current_start_dt.strftime('%H:%M:%S')}")
            self.metric_current.set_value(self.current_activity)
            self.sidebar_active_label.configure(text=self.current_activity)
            self.session_hint.configure(text="Tracking live. Press Stop when finished.")
        else:
            self.current_status_var.set("No active task")
            self.current_start_var.set("Start: --:--:--")
            self.current_duration_var.set("00:00:00")
            self.metric_current.set_value("None")
            self.sidebar_active_label.configure(text="No active task")
            self.sidebar_timer_label.configure(text="00:00:00")
            self.session_hint.configure(text="Pick an activity and press Start / Switch.")

    def update_timer(self):
        if self.current_activity and self.current_start_dt:
            elapsed = int((datetime.now() - self.current_start_dt).total_seconds())
            hms = seconds_to_hms(elapsed)
            self.current_duration_var.set(hms)
            self.sidebar_timer_label.configure(text=hms)
        else:
            self.current_duration_var.set("00:00:00")
            self.sidebar_timer_label.configure(text="00:00:00")

        self.after(1000, self.update_timer)

    def refresh_today_views(self):
        logs = read_today_logs(self.settings["excel_path"])
        self._populate_recent_tree(logs)
        self._populate_log_tree(logs)
        self._populate_breakdown(logs)
        self._update_metrics(logs)

    def _populate_recent_tree(self, logs):
        for item in self.recent_tree.get_children():
            self.recent_tree.delete(item)

        for log in logs[-8:]:
            self.recent_tree.insert(
                "",
                END,
                values=(log["start"], log["end"], log["duration_hms"], log["activity"])
            )

    def _populate_log_tree(self, logs):
        for item in self.log_tree.get_children():
            self.log_tree.delete(item)

        for log in logs:
            self.log_tree.insert(
                "",
                END,
                values=(
                    log["start"],
                    log["end"],
                    f"{log['duration_minutes']:.2f}",
                    log["duration_hms"],
                    log["activity"]
                )
            )

    def _populate_breakdown(self, logs):
        totals = defaultdict(int)
        total_seconds = 0

        for log in logs:
            secs = int(round(log["duration_minutes"] * 60))
            totals[log["activity"]] += secs
            total_seconds += secs

        lines = [
            f"Date: {date.today().strftime('%d/%m/%Y')}",
            "",
            f"Total tracked today: {seconds_to_hms(total_seconds)}",
            "",
            "Breakdown by activity:",
            ""
        ]

        if totals:
            for activity, secs in sorted(totals.items(), key=lambda x: x[1], reverse=True):
                pct = (secs / total_seconds * 100) if total_seconds else 0
                lines.append(f"{activity:<22} {seconds_to_hms(secs)}   ({pct:.1f}%)")
        else:
            lines.append("No entries logged yet today.")

        self.breakdown_text.configure(state="normal")
        self.breakdown_text.delete("1.0", END)
        self.breakdown_text.insert("1.0", "\n".join(lines))
        self.breakdown_text.configure(state="disabled")

    def _update_metrics(self, logs):
        totals = defaultdict(int)
        total_seconds = 0

        for log in logs:
            secs = int(round(log["duration_minutes"] * 60))
            totals[log["activity"]] += secs
            total_seconds += secs

        self.metric_total.set_value(seconds_to_hms(total_seconds))
        self.metric_entries.set_value(str(len(logs)))

        if totals:
            top_activity = max(totals.items(), key=lambda x: x[1])[0]
            self.metric_top.set_value(top_activity)
        else:
            self.metric_top.set_value("--")

        if self.current_activity:
            self.metric_current.set_value(self.current_activity)
        else:
            self.metric_current.set_value("None")


