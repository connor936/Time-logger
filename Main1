        root.rowconfigure(0, weight=1)

        self.sidebar = ttk.Frame(root, width=240, padding=18)
        self.sidebar.grid(row=0, column=0, sticky="ns")
        self.sidebar.grid_propagate(False)

        self.main = ttk.Frame(root, padding=(18, 16, 18, 18))
        self.main.grid(row=0, column=1, sticky="nsew")
        self.main.columnconfigure(0, weight=1)
        self.main.rowconfigure(1, weight=1)

        self._build_sidebar()
        self._build_topbar()

        self.page_host = ttk.Frame(self.main)
        self.page_host.grid(row=1, column=0, sticky="nsew")
        self.page_host.columnconfigure(0, weight=1)
        self.page_host.rowconfigure(0, weight=1)

        self.pages = {}
        for name in ["dashboard", "log", "charts", "settings"]:
            page = ttk.Frame(self.page_host)
            page.grid(row=0, column=0, sticky="nsew")
            self.pages[name] = page

        self._build_dashboard_page()
        self._build_log_page()
        self._build_charts_page()
        self._build_settings_page()

    def _build_sidebar(self):
        ttk.Label(
            self.sidebar,
            text="Time Tracker",
            font=("Segoe UI", 22, "bold")
        ).pack(anchor="w", pady=(6, 22))

        self._create_nav_button("dashboard", "🏠 Dashboard")
        self._create_nav_button("log", "🧾 Today's Log")
        self._create_nav_button("charts", "📊 Charts")
        self._create_nav_button("settings", "⚙ Settings")

        ttk.Separator(self.sidebar).pack(fill=X, pady=18)

        ttk.Button(
            self.sidebar,
            text="Toggle Dark / Light",
            bootstyle="secondary",
            command=self.toggle_theme
        ).pack(fill=X, pady=(0, 8))

    def _create_nav_button(self, page_name: str, text: str):
        btn = ttk.Button(
            self.sidebar,
            text=text,
            bootstyle="secondary-outline",
            command=lambda n=page_name: self.show_page(n)
        )
        btn.pack(fill=X, pady=5)
        self.nav_buttons[page_name] = btn

    def _build_topbar(self):
        topbar = ttk.Frame(self.main)
        topbar.grid(row=0, column=0, sticky="ew", pady=(0, 16))
        topbar.columnconfigure(1, weight=1)

        self.page_title_label = ttk.Label(
            topbar,
            text="Dashboard",
            font=("Segoe UI", 28, "bold")
