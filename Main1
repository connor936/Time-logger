    # -----------------------------
    # NAVIGATION / THEME
    # -----------------------------
    def show_page(self, name):
        titles = {
            "dashboard": "Dashboard",
            "log": "Today's Log",
            "charts": "Charts",
            "settings": "Settings",
        }
        self.pages[name].tkraise()
        self.page_title_label.configure(text=titles.get(name, "Time Tracker"))

        for page_name, button in self.nav_buttons.items():
            button.configure(bootstyle="secondary-outline")
        self.nav_buttons[name].configure(bootstyle="secondary")

        if name == "dashboard":
            self.refresh_dashboard()
        elif name == "log":
            self.refresh_log_page()
        elif name == "charts":
            self.refresh_charts()
        elif name == "settings":
            self.refresh_settings_page()

    def toggle_theme(self):
        dark_set = {"darkly", "superhero", "cyborg"}
        current = self.style.theme.name
        new_theme = "flatly" if current in dark_set else "darkly"
        self.theme_var.set(new_theme)
        self.apply_selected_theme()

    def apply_selected_theme(self):
        theme = self.theme_var.get().strip()
        if not theme:
            return
        try:
            self.style.theme_use(theme)
            self.settings["theme"] = theme
            save_settings(self.settings)
        except Exception as e:
            messagebox.showerror("Theme Error", str(e))

    # -----------------------------
    # SETTINGS ACTIONS
    # -----------------------------
    def browse_excel(self):
        path = filedialog.asksaveasfilename(
            title="Select or create Excel workbook",
            defaultextension=".xlsx",
            filetypes=[("Excel files", "*.xlsx")],
            initialdir=BASE_DIR,
            initialfile=os.path.basename(self.excel_var.get().strip() or DEFAULT_EXCEL_PATH)
        )
        if path:
            self.excel_var.set(path)

    def _refresh_settings_page(self):
        self.excel_var.set(self.settings["excel_path"])
        self.target_var.set(str(self.settings["weekly_target_hours"]))
        self.theme_var.set(self.settings["theme"])

        self.activity_listbox.delete(0, tk.END)
        for activity in self.settings["activities"]:
            self.activity_listbox.insert(tk.END, activity)

    def refresh_settings_page(self):
        self._refresh_settings_page()

    def add_activity(self):
        value = self.new_activity_var.get().strip()
        if not value:
            return

        if value not in self.settings["activities"]:
            self.settings["activities"].append(value)
            self.settings["activities"].sort(key=str.lower)
            save_settings(self.settings)

        self.new_activity_var.set("")
        self.refresh_settings_page()
        self._refresh_activity_dropdown()

    def remove_activity(self):
        selected = self.activity_listbox.curselection()
        if not selected:
            return

        activity = self.activity_listbox.get(selected[0])

        if self.running and activity == self.current_activity_name:
            messagebox.showwarning("In Use", "Stop the running activity before removing it.")
            return

        self.settings["activities"] = [a for a in self.settings["activities"] if a != activity]
        if not self.settings["activities"]:
            self.settings["activities"] = DEFAULT_SETTINGS["activities"][:]

        save_settings(self.settings)
        self.refresh_settings_page()
        self._refresh_activity_dropdown()

    def save_all_settings(self):
        excel_path = self.excel_var.get().strip()
        if not excel_path:
            messagebox.showwarning("Missing Excel Path", "Please select an Excel file.")
            return

        try:
            weekly_target = float(self.target_var.get().strip())
            if weekly_target <= 0:
                raise ValueError
        except Exception:
            messagebox.showwarning("Invalid Weekly Target", "Please enter a valid number greater than 0.")
            return

        self.settings["excel_path"] = excel_path
        self.settings["weekly_target_hours"] = weekly_target
        self.settings["theme"] = self.theme_var.get().strip() or self.settings["theme"]

        ensure_workbook(self.settings["excel_path"])
        save_settings(self.settings)
        self.apply_selected_theme()
        self._refresh_activity_dropdown()
        self.refresh_all()

        messagebox.showinfo("Saved", "Settings saved successfully.")

    def _refresh_activity_dropdown(self):
        values = self.settings["activities"]
        self.activity_combo.configure(values=values)

        current = self.activity_combo.get().strip()
        if values:
            if not current or current not in values:
                self.activity_combo.set(values[0])
        else:
            self.activity_combo.set("")

    # -----------------------------
    # TIMER / LOGGING
    # -----------------------------
    def start_or_switch_activity(self):
        activity_name = self.activity_combo.get().strip()
        if not activity_name:
            messagebox.showwarning("Missing Activity", "Please choose an activity.")
            return

        now = datetime.now()

        if self.running and self.start_dt and self.current_activity_name:
            if activity_name == self.current_activity_name:
                messagebox.showinfo("Already Running", f"'{activity_name}' is already running.")
                return

            append_log_to_excel(
                self.settings["excel_path"],
                self.start_dt,
                now,
                self.current_activity_name
            )

        self._cancel_timer_job()

        self.running = True
        self.start_dt = now
        self.current_activity_name = activity_name
        self.current_activity_var.set(activity_name)

        self.refresh_dashboard()
        self.refresh_log_page()
        self.refresh_charts()
        self._update_timer_loop()

    def stop_activity(self):
        if not self.running or not self.start_dt or not self.current_activity_name:
            return

        append_log_to_excel(
            self.settings["excel_path"],
            self.start_dt,
            datetime.now(),
            self.current_activity_name
        )

        self.running = False
        self.start_dt = None
        self.current_activity_name = None
        self.current_activity_var.set("None")
        self.timer_var.set("00:00:00")
        self._cancel_timer_job()

        self.refresh_all()

    def _cancel_timer_job(self):
        if self.timer_job is not None:
            try:
                self.after_cancel(self.timer_job)
            except Exception:
                pass
            self.timer_job = None

    def _update_timer_loop(self):
        if not self.running or not self.start_dt:
            self.timer_job = None
            return

        elapsed_seconds = int((datetime.now() - self.start_dt).total_seconds())
        self.timer_var.set(seconds_to_hms(elapsed_seconds))

        if self.pages["dashboard"].winfo_ismapped():
            self.refresh_dashboard()

        self.timer_job = self.after(1000, self._update_timer_loop)

    # -----------------------------
    # REFRESHES
    # -----------------------------
    def refresh_all(self):
        self.refresh_dashboard()
        self.refresh_log_page()
        self.refresh_charts()

    def refresh_dashboard(self):
        rows = read_today_logs(self.settings["excel_path"])

        for item in self.dashboard_tree.get_children():
            self.dashboard_tree.delete(item)

        totals = defaultdict(float)
        total_minutes = 0.0

        for row in rows:
            mins = safe_float(row[3], 0.0)
            total_minutes += mins
            totals[str(row[4])] += mins
            self.dashboard_tree.insert("", tk.END, values=(row[1], row[2], row[3], row[4]))

        if self.running and self.start_dt and self.current_activity_name:
            live_minutes = round((datetime.now() - self.start_dt).total_seconds() / 60, 2)
            total_minutes += live_minutes
            totals[self.current_activity_name] += live_minutes
            self.current_activity_var.set(self.current_activity_name)
        else:
            self.current_activity_var.set("None")

        self.total_today_var.set(f"{round(total_minutes, 2)} min")
        self.entries_var.set(str(len(rows) + (1 if self.running else 0)))
        self.top_activity_var.set(max(totals, key=totals.get) if totals else "--")

    def refresh_log_page(self):
        rows = read_today_logs(self.settings["excel_path"])

        for item in self.log_tree.get_children():
            self.log_tree.delete(item)

        for row in rows:
            self.log_tree.insert("", tk.END, values=row)

    def refresh_charts(self):
        for widget in self.chart_area.winfo_children():
            widget.destroy()

        all_rows = read_all_logs(self.settings["excel_path"])
        today_rows = read_today_logs(self.settings["excel_path"])

        today_totals = defaultdict(float)
        for row in today_rows:
            today_totals[str(row[4])] += safe_float(row[3], 0.0)

        if self.running and self.start_dt and self.current_activity_name:
            live_minutes = round((datetime.now() - self.start_dt).total_seconds() / 60, 2)
            today_totals[self.current_activity_name] += live_minutes

        week_dates = self._current_week_dates()
        daily_hours = {day.strftime("%a"): 0.0 for day in week_dates}
        week_total_minutes = 0.0

        for row in all_rows:
            try:
                row_date = datetime.strptime(str(row[0]), "%d/%m/%Y").date()
            except Exception:
                continue

            if row_date in week_dates:
                mins = safe_float(row[3], 0.0)
                daily_hours[row_date.strftime("%a")] += mins / 60
                week_total_minutes += mins

        if self.running and self.start_dt:
            live_minutes = round((datetime.now() - self.start_dt).total_seconds() / 60, 2)
            today_date = datetime.now().date()
            if today_date in week_dates:
                daily_hours[today_date.strftime("%a")] += live_minutes / 60
                week_total_minutes += live_minutes

        week_hours = round(week_total_minutes / 60, 2)
        weekly_target = float(self.settings["weekly_target_hours"])
        completion = round((week_hours / weekly_target) * 100, 1) if weekly_target else 0.0

        self.chart_summary_label.configure(
            text=f"Worked this week: {week_hours}h   |   Target: {weekly_target}h   |   Completion: {completion}%"
        )

        fig = Figure(figsize=(11, 4.4), dpi=100)
        ax1 = fig.add_subplot(121)
        ax2 = fig.add_subplot(122)

        labels = list(today_totals.keys())
        values = list(today_totals.values())

        if values and sum(values) > 0:
            ax1.pie(values, labels=labels, autopct="%1.1f%%", startangle=90)
            ax1.set_title("Today's Activity Breakdown")
        else:
            ax1.text(0.5, 0.5, "No data today", ha="center", va="center")
            ax1.set_title("Today's Activity Breakdown")
            ax1.axis("off")

        x_labels = list(daily_hours.keys())
        y_values = [daily_hours[d] for d in x_labels]
        ax2.bar(x_labels, y_values)
        ax2.set_title("Hours This Week")
        ax2.set_ylabel("Hours")

        fig.tight_layout()

        canvas = FigureCanvasTkAgg(fig, master=self.chart_area)
        canvas.draw()
        canvas.get_tk_widget().pack(fill=BOTH, expand=YES)

    def _current_week_dates(self):
        today = datetime.now().date()
        monday = today - timedelta(days=today.weekday())
        return [monday + timedelta(days=i) for i in range(7)]

    def on_close(self):
        self._cancel_timer_job()
        self.destroy()


