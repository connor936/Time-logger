APP_TITLE = "Enterprise Time Tracker"
BASE_DIR = os.path.abspath(os.path.dirname(__file__))
SETTINGS_FILE = os.path.join(BASE_DIR, "time_tracker_settings.json")
DEFAULT_EXCEL_PATH = os.path.join(BASE_DIR, "master_time_log.xlsx")

AVAILABLE_THEMES = [
    "flatly", "litera", "minty", "pulse", "morph", "journal",
    "darkly", "superhero", "cyborg"
]

DEFAULT_SETTINGS = {
    "excel_path": DEFAULT_EXCEL_PATH,
    "activities": [
        "Change Request",
        "Incident",
        "Meeting",
        "Development",
        "Admin",
        "Break"
    ],
    "weekly_target_hours": 40.0,
    "theme": "flatly"
}


def ensure_parent_folder(file_path: str):
    folder = os.path.dirname(file_path)
    if folder and not os.path.exists(folder):
        os.makedirs(folder, exist_ok=True)


def seconds_to_hms(total_seconds: int) -> str:
    total_seconds = max(0, int(total_seconds))
    h = total_seconds // 3600
    m = (total_seconds % 3600) // 60
    s = total_seconds % 60
    return f"{h:02}:{m:02}:{s:02}"


def safe_float(value, default=0.0):
    try:
        return float(value)
    except Exception:
        return default


def load_settings():
    if not os.path.exists(SETTINGS_FILE):
        ensure_parent_folder(SETTINGS_FILE)
        save_settings(DEFAULT_SETTINGS.copy())
        return DEFAULT_SETTINGS.copy()

    try:
        with open(SETTINGS_FILE, "r", encoding="utf-8") as f:
            settings = json.load(f)
    except Exception:
        save_settings(DEFAULT_SETTINGS.copy())
        return DEFAULT_SETTINGS.copy()

    merged = DEFAULT_SETTINGS.copy()
    merged.update(settings)

    cleaned_activities = []
    for item in merged.get("activities", []):
        value = str(item).strip()
        if value and value not in cleaned_activities:
            cleaned_activities.append(value)

    merged["activities"] = cleaned_activities or DEFAULT_SETTINGS["activities"][:]

    weekly_target = safe_float(merged.get("weekly_target_hours", 40.0), 40.0)
    merged["weekly_target_hours"] = weekly_target if weekly_target > 0 else 40.0

    theme = str(merged.get("theme", "flatly")).strip()
    merged["theme"] = theme if theme in AVAILABLE_THEMES else "flatly"

    excel_path = str(merged.get("excel_path", DEFAULT_EXCEL_PATH)).strip()
    merged["excel_path"] = excel_path or DEFAULT_EXCEL_PATH

    return merged


def save_settings(settings):
    ensure_parent_folder(SETTINGS_FILE)
    with open(SETTINGS_FILE, "w", encoding="utf-8") as f:
        json.dump(settings, f, indent=4)


def ensure_workbook(excel_path: str):
    ensure_parent_folder(excel_path)

    if os.path.exists(excel_path):
        return

    wb = Workbook()
    ws = wb.active
    ws.title = "Time Log"
    ws.append(["Date", "Start", "End", "Minutes", "Activity"])
    wb.save(excel_path)


def append_log_to_excel(excel_path: str, start_dt: datetime, end_dt: datetime, activity: str):
    ensure_workbook(excel_path)

    minutes = round((end_dt - start_dt).total_seconds() / 60, 2)
    if minutes < 0:
        minutes = 0

    wb = load_workbook(excel_path)
    ws = wb.active
    ws.append([
        start_dt.strftime("%d/%m/%Y"),
        start_dt.strftime("%H:%M:%S"),
        end_dt.strftime("%H:%M:%S"),
        minutes,
        activity
    ])
    wb.save(excel_path)


def read_all_logs(excel_path: str):
    ensure_workbook(excel_path)

    wb = load_workbook(excel_path, data_only=True)
    ws = wb.active

    rows = []
    for row in ws.iter_rows(min_row=2, values_only=True):
        if not row or len(row) < 5:
            continue

        date_val = "" if row[0] is None else str(row[0]).strip()
        start_val = "" if row[1] is None else str(row[1]).strip()
        end_val = "" if row[2] is None else str(row[2]).strip()
        mins_val = safe_float(row[3], 0.0)
        activity_val = "" if row[4] is None else str(row[4]).strip()

        if not date_val and not activity_val:
            continue

        rows.append((date_val, start_val, end_val, mins_val, activity_val))

    return rows


def read_today_logs(excel_path: str):
    today = datetime.now().strftime("%d/%m/%Y")
    return [row for row in read_all_logs(excel_path) if str(row[0]) == today]


class TimeTrackerApp(ttk.Window):
    def __init__(self):
        self.settings = load_settings()
        ensure_workbook(self.settings["excel_path"])

        super().__init__(themename=self.settings["theme"])

        self.title(APP_TITLE)
        self.geometry("1420x900")
        self.minsize(1100, 720)

        self.running = False
        self.start_dt = None
        self.current_activity_name = None
        self.timer_job = None

        self.total_today_var = tk.StringVar(value="0.0 min")
        self.entries_var = tk.StringVar(value="0")
        self.current_activity_var = tk.StringVar(value="None")
        self.top_activity_var = tk.StringVar(value="--")
        self.timer_var = tk.StringVar(value="00:00:00")

        self.excel_var = tk.StringVar(value=self.settings["excel_path"])
        self.target_var = tk.StringVar(value=str(self.settings["weekly_target_hours"]))
        self.theme_var = tk.StringVar(value=self.settings["theme"])
        self.new_activity_var = tk.StringVar()

        self.nav_buttons = {}

        self._build_ui()
        self._refresh_activity_dropdown()
        self._refresh_settings_page()
        self.show_page("dashboard")
        self.refresh_all()

        self.protocol("WM_DELETE_WINDOW", self.on_close)

